# Configuration SwiftFormat pour MaxiTerm.
--swiftversion 6.0

--exclude .build,DerivedData,**/.build,Packages/**/.build

--indent 4
--maxwidth 120
--wraparguments before-first
--wrapparameters before-first
--wrapcollections before-first
--self remove
--importgrouping testable-bottom
--commas always
--trimwhitespace always
